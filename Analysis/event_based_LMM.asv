lme_swrevt4 = fitlme(ProcPeakTbl2,'Peak_one_sec ~ BeforeAfter + swrID + (1|mouseID) + (1|sess:mouseID)');%(ProcPeakTbl,'Peak ~ BeforeAfter + swrID + PrePost + (1|mouseID) + (1|sess)');
disp(lme_swrevt4)
%AIC: 1.1034e+05 
% prepost beta -0.072658 
