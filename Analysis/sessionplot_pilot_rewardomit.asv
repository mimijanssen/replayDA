%% Video file
v = VideoReader(videoFile);

%% Convert photobeam times to frame indices
% fpos.tvec = timestamps for DLC positions
% all_pb_sorted = photobeam times in seconds (first overall = all_pb_sorted(1))
fps = v.FrameRate;

% First photobeam frame
firstTime = all_pb_sorted(1);
firstFrame = round(firstTime * fps);
firstFrame = max(1, min(firstFrame, v.NumFrames)); % clamp

% Last photobeam frame
lastTime = all_pb_sorted(end);
lastFrame = round(lastTime * fps);
lastFrame = max(1, min(lastFrame, v.NumFrames)); % clamp

%% Extract frames
firstFrameImg = read(v, firstFrame);
lastFrameImg  = read(v, lastFrame);


%% ============================================================
% OVERLAY PHOTOBEAM BREAKS ON VIDEO FRAMES
