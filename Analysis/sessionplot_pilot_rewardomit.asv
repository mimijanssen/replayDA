% Plot full trajectory
plot(padbodyx, padbodyy, '.', 'Color', [0.85 0.85 0.85 0.3])

% Plot left photobeam points
scatter(left_x, left_y, 80, left_c, 'filled', 'MarkerFaceAlpha', 0.5, 'MarkerEdgeAlpha', 0.5)

% Plot right photobeam points
scatter(right_x, right_y, 80, right_c, 'filled', 'MarkerFaceAlpha', 0.5, 'MarkerEdgeAlpha', 0.5)

% Highlight first and last events
scatter(all_x_sorted(1), all_y_sorted(1), 250, 'k', 'p', 'filled')  % first event
scatter(all_x_sorted(end), all_y_sorted(end), 250, 'k', '*')        % last event

set(gca,'YDir','reverse')
axis equal
xlabel('X position')
ylabel('Y position')
title('Photobeam on Last Event Frame')

saveas(gcf, 'LastPhotobeamFrame.png');


