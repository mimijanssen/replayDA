%% Plot trajectory and photobeam points
%% ============================================================
% MIDBODY POSITION AT PHOTOBEAM BREAKS
% Left = purple, Right = orange/yellow
% Slightly transparent points, no gradient
% First overall = filled pentagram
% Last overall = star
% =============================================================

%% Align photobeam times to video timebase
pos_t = fpos.tvec;  % DLC timestamps in seconds

% Find nearest DLC frame indices
left_idx  = nearest_idx3(left_pb, pos_t);
right_idx = nearest_idx3(right_pb, pos_t);

% Extract positions
left_x  = padbodyx(left_idx);
left_y  = padbodyy(left_idx);
right_x = padbodyx(right_idx);
right_y = padbodyy(right_idx);

%% Sort each side chronologically
[left_pb, sortL] = sort(left_pb);
left_x = left_x(sortL);
left_y = left_y(sortL);

[right_pb, sortR] = sort(right_pb);
right_x = right_x(sortR);
right_y = right_y(sortR);

%% Combine all events to find first and last overall
all_pb  = [left_pb(:); right_pb(:)];
all_x   = [left_x(:); right_x(:)];
all_y   = [left_y(:); right_y(:)];

[all_pb_sorted, sort_idx] = sort(all_pb);
all_x_sorted = all_x(sort_idx);
all_y_sorted = all_y(sort_idx);

first_x = all_x_sorted(1);
first_y = all_y_sorted(1);

last_x  = all_x_sorted(end);
last_y  = all_y_sorted(end);

%% ===================== PLOT =====================
figure; hold on

% Plot full trajectory in gray
plot(padbodyx, padbodyy, '.', 'Color', [0.85 0.85 0.85])

% Plot left photobeam points (purple), semi-transparent
scatter(left_x, left_y, 80, left_c, 'filled', ...
    'MarkerFaceAlpha', 0.5, 'MarkerEdgeAlpha', 0.5)

% Plot right photobeam points (orange/yellow), semi-transparent
scatter(right_x, right_y, 80, right_c, 'filled', ...
    'MarkerFaceAlpha', 0.5, 'MarkerEdgeAlpha', 0.5)

% First overall event (filled pentagram)
scatter(first_x, first_y, 250, 'k', 'p', 'filled')

% Last overall event (star)
scatter(last_x, last_y, 250, 'k', '*')

% Flip Y-axis to match video coordinates
set(gca,'YDir','reverse')
axis equal
xlabel('X position')
ylabel('Y position')
title('Photobeam Break Locations (Left = Purple, Right = Orange/Yellow)')

legend({'Trajectory','Left PB','Right PB','First Overall','Last Overall'})
legend boxoff
set(gcf,'Color',[1 1 1])
% left is first 

%% PLot photobeam video 

%% ============================================================
% OVERLAY PHOTOBEAM BREAKS ON VIDEO FRAMES
