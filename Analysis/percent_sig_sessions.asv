lme_swrsess1 = fitlme(tbl,'SWRDA ~ PrePost + (1|Mouse) + (1|Session)');%(ProcPeakTbl,'Peak ~ BeforeAfter + swrID + PrePost + (1|mouseID) + (1|sess)');
% 148.1 BIC 
% 0.03 pvalue diff between before and afer

lme_swrsess2 =  fitlme(tbl,'SWRDA ~ PrePost + (1|Mouse) + (1|Session:Mouse)');
%143.26 BIC (better- significantly using the compare function.)
%0.013 prepost

lme_swrsess3 = fitlme(tbl,'SWRDA ~ PrePost + (1|Mouse) + (1+ Session|Mouse)');%(ProcPeakTbl,'Peak ~ BeforeAfter + swrID + PrePost + (1|mouseID) + (1|sess)');
% BIC 154

% what about adding seess as a variable? and then making a new table
% establishig early vs. late... 
lme_swrsess4 =  fitlme(tbl,'SWRDA ~ PrePost + Session + (1|Mouse)');
% sess is not significant 
compare(lme_swrsess4, lme_swrsess2) % sess 2 is significantly better.... lower BIC and AIC. 

%% edit table 
tbl2 = tbl;
for i = 1:1:length(tbl2.('Session')(:,1))
    if tbl2.('Session')(i) == 1 | tbl2.('Session')(i) == 2 | tbl2.('Session')(i) == 3 | tbl2.('Session')(i) == 4 
        tbl2.('Session')(i) = 1 ;% one for early
    else
        tbl2.('Session')(i) = 2; % 2 for late
    end
end

